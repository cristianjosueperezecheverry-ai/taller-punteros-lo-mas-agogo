#include <iostream>
using namespace std;

void calcularSumaFilas(int** matriz, int n, int m) {
    for(int i = 0; i < n; i++) {
        int suma = 0;
        for(int j = 0; j < m; j++) suma += *(*(matriz + i) + j); 
        cout << "Fila " << i << ": " << suma << endl;
    }
}

int encontrarMayor(int** matriz, int n, int m) {
    int mayor = **matriz;
    for(int i = 0; i < n; i++)
        for(int j = 0; j < m; j++)
            if(*(*(matriz + i) + j) > mayor) mayor = *(*(matriz + i) + j);
    return mayor;
}
